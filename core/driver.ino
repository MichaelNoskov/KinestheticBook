// ===================== Управление моторами =====================
void setup_pin(gpio_num_t pin_num) {
    gpio_reset_pin(pin_num);
    gpio_set_direction(pin_num, GPIO_MODE_OUTPUT);
}
void set_pin(gpio_num_t pin_num, uint32_t level) { gpio_set_level(pin_num, level); }
void reset_pins() { for (int i=0; i<5; i++) set_pin(pins[i], 0); }

void activateMotor(const Task &task) {
    uint8_t idx = task.motor - 1;
    for (int i=0; i<5; i++) set_pin(pins[i], motorPins[idx][i]);
    motorActive = true;
    currentTask = task;
    motorEndTime = millis() + task.duration;
}

void stopMotorAndNotify() {
    reset_pins();
    motorActive = false;
    if (connectionActive) {
        String doneMsg = "DONE:" + String(currentTask.id);
        pTxChar->setValue(doneMsg.c_str());
        pTxChar->notify();
    }
}

void tryStartNextTask() {
    if (motorActive || queueCount == 0) return;
    Task nextTask = queue[queueHead];
    queueHead = (queueHead + 1) % QUEUE_SIZE;
    queueCount--;
    activateMotor(nextTask);
}

int32_t addToQueue(const Task &task) {
    if (task.id == 0 || task.motor < 1 || task.motor > NUM_MOTORS || 
        task.duration == 0 || task.duration > MAX_DURATION_MS)
        return -1;
    if (queueCount < QUEUE_SIZE) {
        queue[queueTail] = task;
        queueTail = (queueTail + 1) % QUEUE_SIZE;
        queueCount++;
        if (!motorActive) tryStartNextTask();
        return 0;
    } else {
        if (motorActive && (long)(motorEndTime - millis()) > 0) 
            return (int32_t)(motorEndTime - millis());
        return 0;
    }
}

bool parseCommand(char* cmd, Task &task) {
    if (strncmp(cmd, "PING,", 5) == 0) {
        return false;
    }
    if (strncmp(cmd, "GYRO,", 5) == 0) {
        int val = atoi(cmd+5);
        if (val >= 0 && val <= 60000) {
            gyroIntervalMs = val;
            lastGyroSendTime = millis();
            if (val == 0) {
                lastSentPitch = lastSentRoll = lastSentYaw = 0;
            }
        }
        return false;
    }
    int firstComma = -1, secondComma = -1;
    for (int i=0; cmd[i]; i++) {
        if (cmd[i]==',') {
            if (firstComma==-1) firstComma = i;
            else { secondComma = i; break; }
        }
    }
    if (firstComma==-1 || secondComma==-1) return false;
    cmd[firstComma] = '\0';
    cmd[secondComma] = '\0';
    task.id = (uint16_t)atoi(cmd);
    task.motor = (uint8_t)atoi(cmd+firstComma+1);
    task.duration = (uint16_t)atoi(cmd+secondComma+1);
    cmd[firstComma] = ',';
    cmd[secondComma] = ',';
    return (task.id != 0 && task.motor >= 1 && task.motor <= NUM_MOTORS &&
            task.duration > 0 && task.duration <= MAX_DURATION_MS);
}

void resetControllerState() {
    if (motorActive) { reset_pins(); motorActive = false; }
    queueHead = queueTail = queueCount = 0;
    lastPingTime = millis();
    gyroIntervalMs = 0;
    lastSentPitch = lastSentRoll = lastSentYaw = 0;
}

// ===================== BLE коллбэки =====================
class MyServerCallbacks : public BLEServerCallbacks {
    void onConnect(BLEServer* pServer) override {
        connectionActive = true;
        resetControllerState();
        lastPingTime = millis();
        currentState = STATE_ACTIVE;
    }
    void onDisconnect(BLEServer* pServer) override {
        connectionActive = false;
        resetControllerState();
        currentState = STATE_BLUETOOTH_WAIT;
        pAdvertising->start();
    }
};

class MyCharacteristicCallbacks : public BLECharacteristicCallbacks {
    void onWrite(BLECharacteristic *pCharacteristic) override {
        String value = pCharacteristic->getValue();
        if (value.length() > 0 && value.length() < 32) {
            char buffer[32];
            value.toCharArray(buffer, 32);

            if (strncmp(buffer, "PING,", 5) == 0) {
                lastPingTime = millis();
                return;
            }

            if (strcmp(buffer, "MOTORS") == 0) {
                String msg = "MOTORS=" + String(NUM_MOTORS);
                pTxChar->setValue(msg.c_str());
                pTxChar->notify();
                return;
            }

            Task newTask;
            if (parseCommand(buffer, newTask)) {
                int32_t waitMs = addToQueue(newTask);
                if (waitMs == 0) {
                    String ack = "RECEIVED:" + String(newTask.id);
                    pTxChar->setValue(ack.c_str());
                    pTxChar->notify();
                } else if (waitMs > 0) {
                    String fullMsg = "QUEUE_FULL:" + String(newTask.id) + "," + String(waitMs);
                    pTxChar->setValue(fullMsg.c_str());
                    pTxChar->notify();
                } else {
                    pTxChar->setValue(("INVALID:" + String(newTask.id)).c_str());
                    pTxChar->notify();
                }
            }

        }
    }
};

// ===================== Работа с дисплеем =====================
void drawFrame(const uint8_t* frame) {
    int i = 0;
    while (true) {
        uint8_t x = pgm_read_byte(frame + i++);
        uint8_t y = pgm_read_byte(frame + i++);
        if (x == 0xFF && y == 0xFF) break;
        u8g2.drawPixel(x, y);
    }
}

void drawAnimation(const uint8_t* const frames[], int numFrames, int delayMs) {
    for (int i = 0; i < numFrames; i++) {
        u8g2.clearBuffer();
        drawFrame(frames[i]);
        u8g2.sendBuffer();
        delay(delayMs);
    }
}

void drawElephantAnimation(int delayMs) {
    const int numFrames = sizeof(animation_frames) / sizeof(animation_frames[0]);
    drawAnimation(animation_frames, numFrames, delayMs);
}

void drawLoadingAnimation(const char* message, void (*drawIcon)(int x, int y)) {
    static int phase = 0;
    static unsigned long lastAnim = 0;
    if (millis() - lastAnim > 120) {
        lastAnim = millis();
        phase = (phase + 1) % 6;
    }
    u8g2.clearBuffer();
    const float ANGLE_STEP = 2 * PI / 6;
    for (int i = 0; i < 6; i++) {
        int idx = (phase - i + 6) % 6;
        float angle = idx * ANGLE_STEP - PI / 2;
        int x = 36 + (int)(7 * cos(angle));
        int y = 13 + (int)(7 * sin(angle));
        float r = (i < 2) ? 1.0f : (i < 4) ? 0.5f : 0.0f;
        if (r > 0) u8g2.drawDisc(x, y, (int)(r + 0.5f));
        else u8g2.drawPixel(x, y);
    }
    u8g2.setFont(u8g2_font_5x8_tf);
    int msgWidth = strlen(message) * 5;
    int iconWidth = (drawIcon != nullptr) ? 8 : 0;
    int totalWidth = iconWidth + msgWidth;
    int startX = (72 - totalWidth) / 2;
    if (startX < 0) startX = 0;
    int msgY = 36;
    if (drawIcon) {
        drawIcon(startX, msgY - 7);
        startX += 10;
    }
    u8g2.drawStr(startX, msgY, message);
    u8g2.sendBuffer();
}

void drawBluetoothIcon(int x, int y) {
    u8g2.drawLine(x, y, x, y + 7);
    u8g2.drawLine(x, y + 3.5, x - 2, y + 5.25);
    u8g2.drawLine(x, y + 3.5, x - 2, y + 1.75);
    u8g2.drawLine(x, y + 3.5, x + 3.75, y + 5.25);
    u8g2.drawLine(x + 3.75, y + 5.25, x, y + 7);
    u8g2.drawLine(x, y, x + 3.75, y + 1.75);
    u8g2.drawLine(x + 3.75, y + 1.75, x, y + 3.5);
}

void drawAngleValues(float pitch, float roll, float yaw) {
    u8g2.setFont(u8g2_font_5x8_tf);
    u8g2.setCursor(0, 10); u8g2.print("P:"); u8g2.setCursor(20, 10); u8g2.print((int)pitch);
    u8g2.setCursor(0, 20); u8g2.print("R:"); u8g2.setCursor(20, 20); u8g2.print((int)roll);
    u8g2.setCursor(0, 30); u8g2.print("Y:"); u8g2.setCursor(20, 30); u8g2.print((int)yaw);
}

void drawMotorStatus() {
    if (motorActive) {
        u8g2.setFont(u8g2_font_5x7_tf);
        char buf[16];
        unsigned long remaining = (motorEndTime > millis()) ? (motorEndTime - millis()) / 1000 + 1 : 0;
        sprintf(buf, "M%d %lds", currentTask.motor, remaining);
        u8g2.drawStr(0, 40, buf);
    } else if (queueCount > 0) {
        u8g2.setFont(u8g2_font_5x7_tf);
        char buf[16];
        sprintf(buf, "Queue: %d", queueCount);
        u8g2.drawStr(0, 40, buf);
    }
}

// ===================== Математика для отрисовки данных с гироскопа =====================
void getRotationMatrix(float yawRad, float rollRad, float pitchRad, float m[3][3]) {
    float cy = cos(yawRad), sy = sin(yawRad);
    float cr = cos(rollRad), sr = sin(rollRad);
    float cp = cos(pitchRad), sp = sin(pitchRad);
    float Ry[3][3] = {{cy, 0, sy}, {0, 1, 0}, {-sy, 0, cy}};
    float Rx[3][3] = {{1, 0, 0}, {0, cr, -sr}, {0, sr, cr}};
    float Rz[3][3] = {{cp, -sp, 0}, {sp, cp, 0}, {0, 0, 1}};
    float tmp[3][3];
    for (int i = 0; i < 3; i++)
        for (int j = 0; j < 3; j++) {
            tmp[i][j] = 0;
            for (int k = 0; k < 3; k++) tmp[i][j] += Ry[i][k] * Rx[k][j];
        }
    for (int i = 0; i < 3; i++)
        for (int j = 0; j < 3; j++) {
            m[i][j] = 0;
            for (int k = 0; k < 3; k++) m[i][j] += tmp[i][k] * Rz[k][j];
        }
}

void applyMatrix(float m[3][3], float &x, float &y, float &z) {
    float tx = m[0][0]*x + m[0][1]*y + m[0][2]*z;
    float ty = m[1][0]*x + m[1][1]*y + m[1][2]*z;
    float tz = m[2][0]*x + m[2][1]*y + m[2][2]*z;
    x = tx; y = ty; z = tz;
}

void project(float x, float y, float z, float scale, int &sx, int &sy) {
    sx = (int)(x * scale + 0.5f);
    sy = (int)(-y * scale + 0.5f);
}

bool freePosition(int x, int y, const int labelX[], const int labelY[], int labelsDrawn) {
    for (int i = 0; i < labelsDrawn; i++)
        if (abs(x - labelX[i]) < 6 && abs(y - labelY[i]) < 5) return false;
    return true;
}

bool findLabelPos(int tipX, int tipY, float dirX, float dirY, int &lx, int &ly) {
    float len = sqrt(dirX*dirX + dirY*dirY);
    if (len < 0.5f) return false;
    float nx = dirX / len, ny = dirY / len;
    int tries[4][2] = {
        {tipX + (int)(nx*4), tipY + (int)(ny*4) + 3},
        {tipX + (int)(nx*3 - ny*2), tipY + (int)(ny*3 + nx*2) + 3},
        {tipX + (int)(nx*3 + ny*2), tipY + (int)(ny*3 - nx*2) + 3},
        {tipX - (int)(nx*2), tipY - (int)(ny*2) + 3}
    };
    for (int i = 0; i < 4; i++) {
        if (tries[i][0] >= 5 && tries[i][0] <= 66 && tries[i][1] >= 7 && tries[i][1] <= 35) {
            lx = tries[i][0]; ly = tries[i][1];
            return true;
        }
    }
    return false;
}

void drawArrow(float ax, float ay, float az, const char* label,
               float yawRad, float rollRad, float pitchRad,
               int labelX[], int labelY[], int &labelsDrawn) {
    float m[3][3];
    getRotationMatrix(yawRad, rollRad, pitchRad, m);
    float x = ax, y = ay, z = az;
    applyMatrix(m, x, y, z);
    int dx, dy;
    project(x, y, z, 8.0f, dx, dy);
    int x1 = 55 + dx;
    int y1 = 15 + dy;
    u8g2.drawLine(55, 15, x1, y1);
    float sx = (float)(x1 - 55);
    float sy = (float)(y1 - 15);
    float len = sqrt(sx*sx + sy*sy);
    if (len > 0.5f) {
        float nx = sx / len, ny = sy / len;
        float px = -ny, py = nx;
        float baseX = x1 - nx * 2.0f;
        float baseY = y1 - ny * 2.0f;
        u8g2.drawLine(x1, y1, (int)(baseX + px*1.5f), (int)(baseY + py*1.5f));
        u8g2.drawLine(x1, y1, (int)(baseX - px*1.5f), (int)(baseY - py*1.5f));
    }
    int lx, ly;
    if (findLabelPos(x1, y1, sx, sy, lx, ly) && freePosition(lx, ly, labelX, labelY, labelsDrawn)) {
        u8g2.drawStr(lx, ly, label);
        labelX[labelsDrawn] = lx;
        labelY[labelsDrawn] = ly;
        labelsDrawn++;
    }
}

void drawGizmo(float pitchDeg, float rollDeg, float yawDeg) {
    float yawRad = yawDeg * PI / 180.0f;
    float rollRad = rollDeg * PI / 180.0f;
    float pitchRad = pitchDeg * PI / 180.0f;
    int labelX[3], labelY[3];
    int labelsDrawn = 0;
    drawArrow(1, 0, 0, "X", yawRad, rollRad, pitchRad, labelX, labelY, labelsDrawn);
    drawArrow(0, 1, 0, "Y", yawRad, rollRad, pitchRad, labelX, labelY, labelsDrawn);
    drawArrow(0, 0, 1, "Z", yawRad, rollRad, pitchRad, labelX, labelY, labelsDrawn);
    u8g2.drawDisc(55, 15, 1);
}


void setup() {
    Wire.begin(5, 6);
    Wire.setClock(100000);
    u8g2.begin();
    for (int i=0; i<5; i++) setup_pin(pins[i]);
    reset_pins();

    drawElephantAnimation(100);
    delay(500);

    // Поиск BMI160
    for (int addr=0x68; addr<=0x69; addr++) {
        Wire.beginTransmission(addr);
        if (Wire.endTransmission()==0) { bmi160Addr = addr; break; }
    }
    if (bmi160Addr != 0) {
        // Сброс
        Wire.beginTransmission(bmi160Addr);
        Wire.write(0x7E); Wire.write(0xB6);
        Wire.endTransmission();
        delay(100);
        
        // Включение акселерометра
        Wire.beginTransmission(bmi160Addr);
        Wire.write(0x7E); Wire.write(0x11);
        Wire.endTransmission();
        delay(50);
        
        // Включение гироскопа
        Wire.beginTransmission(bmi160Addr);
        Wire.write(0x7E); Wire.write(0x15);
        Wire.endTransmission();
        delay(100);
    }
    lastSensorTime = millis();

    // BLE
    BLEDevice::init("ESP32-C3-Motion");
    pServer = BLEDevice::createServer();
    pServer->setCallbacks(new MyServerCallbacks());
    BLEService *pService = pServer->createService(SERVICE_UUID);
    pRxChar = pService->createCharacteristic(CHAR_UUID_RX, BLECharacteristic::PROPERTY_WRITE);
    pRxChar->setCallbacks(new MyCharacteristicCallbacks());
    pTxChar = pService->createCharacteristic(CHAR_UUID_TX, BLECharacteristic::PROPERTY_NOTIFY);
    pTxChar->addDescriptor(new BLE2902());
    pService->start();
    pAdvertising = BLEDevice::getAdvertising();
    pAdvertising->start();

    currentState = STATE_BLUETOOTH_WAIT;
    connectionActive = false;
}


void loop() {
    unsigned long now = millis();

    // Управление моторами
    if (motorActive && (long)(now - motorEndTime) >= 0) {
        stopMotorAndNotify();
        tryStartNextTask();
    }

    // Таймаут по PING
    if (connectionActive && (long)(now - lastPingTime) >= PING_TIMEOUT_MS) {
      connectionActive = false;
      resetControllerState();
      currentState = STATE_BLUETOOTH_WAIT;
    }

    // Отправка данных гироскопа (если есть изменения >5 градусов)
    if (connectionActive && gyroIntervalMs > 0) {
        if ((long)(now - lastGyroSendTime) >= gyroIntervalMs) {
            bool changed = (fabs(pitch - lastSentPitch) >= GYRO_SEND_THRESH) ||
                           (fabs(roll - lastSentRoll) >= GYRO_SEND_THRESH) ||
                           (fabs(yaw - lastSentYaw) >= GYRO_SEND_THRESH);
            if (changed) {
                char gyroMsg[32];
                snprintf(gyroMsg, 32, "GYRO,%.1f,%.1f,%.1f", pitch, roll, yaw);
                pTxChar->setValue(gyroMsg);
                pTxChar->notify();
                lastSentPitch = pitch;
                lastSentRoll = roll;
                lastSentYaw = yaw;
            }
            lastGyroSendTime = now;
        }
    }

    // Чтение BMI160 и обновление углов
    if (bmi160Addr != 0) {
        Wire.beginTransmission(bmi160Addr);
        Wire.write(0x0C);
        Wire.endTransmission(false);
        Wire.requestFrom(bmi160Addr, 12);
        if (Wire.available() >= 12) {
            int16_t gx = Wire.read() | (Wire.read() << 8);
            int16_t gy = Wire.read() | (Wire.read() << 8);
            int16_t gz = Wire.read() | (Wire.read() << 8);
            int16_t ax = Wire.read() | (Wire.read() << 8);
            int16_t ay = Wire.read() | (Wire.read() << 8);
            int16_t az = Wire.read() | (Wire.read() << 8);
            float dt = (now - lastSensorTime) / 1000.0;
            lastSensorTime = now;
            roll = atan2((float)ay, (float)az) * 57.3;
            pitch = atan2(-(float)ax, sqrt((float)ay*ay + (float)az*az)) * 57.3;
            float gz_deg = gz / 16.4;
            if (abs(gz_deg) > 0.6) yaw += gz_deg * dt;
        }
    }

    // Отрисовка дисплея
    switch (currentState) {
        case STATE_STARTUP:
            currentState = STATE_BLUETOOTH_WAIT;
            break;
        case STATE_BLUETOOTH_WAIT:
            drawLoadingAnimation("Bluetooth", drawBluetoothIcon);
            break;
        case STATE_ACTIVE:
            if (!connectionActive) {
                currentState = STATE_BLUETOOTH_WAIT;
                break;
            }
            u8g2.clearBuffer();
            drawAngleValues(pitch, roll, yaw);
            drawGizmo(pitch, roll, yaw);
            drawMotorStatus();
            u8g2.sendBuffer();
            break;
    }
    delay(30);
}